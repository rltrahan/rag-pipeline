# ===========================================
# RAG Pipeline Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values.
# The .env file should NEVER be committed to Git.

# -------------------------------------------
# PostgreSQL + pgvector Database Connection
# -------------------------------------------
DB_HOST=192.168.1.18
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# -------------------------------------------
# Ollama Connection (for embeddings & generation)
# -------------------------------------------
# Use the hostname or IP of the machine running Ollama
OLLAMA_HOST=http://192.168.1.11:11434

# Optional: Default embedding model
# EMBEDDING_MODEL=nomic-embed-text

# Optional: Default generation model
# GENERATION_MODEL=phi4